    {
      "name": "View Products",
      "short_name": "Products",
      "description": "View and manage inventory",
      "url": "/?page=products",
      "icons": [
        {
          "src": "/images/shortcut-products-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Sales History",
      "short_name": "Sales",
